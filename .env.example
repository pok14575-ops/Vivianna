# Vivianna — machine-specific paths. Copy this file to ".env" and fill in.
# ".env" is gitignored; ".env.example" is the committed template.
# Notes: no quotes needed, no spaces around "=", paths may contain spaces.

# --- llama.cpp server (external download) ---
# Full path to llama-server.exe (or llama-server on Linux/Mac).
LLAMA_EXE=

# --- LLM weights (download from official Qwen GGUF release; do NOT ship) ---
# run_vivianna.bat uses the MTP variant (faster decode); start_server.bat the plain one.
VIVIANNA_LLM_MODEL=
VIVIANNA_LLM_MODEL_PLAIN=

# --- API keys directory (one <name>.txt per key: groq.txt, tavily.txt, exa.txt) ---
# Recommended: a folder OUTSIDE the repo. Defaults to <repo>/keys if unset.
VIVIANNA_KEY_DIR=

# --- TTS (Kokoro) model files (external download). Default <repo>/models if unset. ---
VIVIANNA_TTS_MODEL=
VIVIANNA_TTS_VOICES=

# --- Local ASR (faster-whisper / CT2) model dir. Auto-fetched here if missing. ---
# Default <repo>/models/asr if unset.
VIVIANNA_ASR_MODEL_DIR=

# --- Optional overrides (sensible repo-relative defaults if left blank) ---
# VIVIANNA_DATA_DIR=        # memory store + caches (default <repo>/data)
# VIVIANNA_ROLLBACK_DIR=    # timestamped memory backups (default <repo>/backups)
